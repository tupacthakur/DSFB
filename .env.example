# Server-only secrets
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RISTA_API_KEY=your_rista_api_key_here
RISTA_SECRET_KEY=your_rista_secret_key_here
DATABASE_URL=postgresql://user:password@host:5432/koravo

# Runtime configuration
NODE_ENV=production
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_MS=60000
ALLOWED_ORIGIN=https://your-production-domain.com

# Client-safe variables
NEXT_PUBLIC_APP_NAME=Koravo
NEXT_PUBLIC_APP_VERSION=1.0.0
